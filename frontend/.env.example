# Frontend Environment Variables
# Copy this file to .env and fill in your actual values

# API Gateway URL - Backend API endpoint
# IMPORTANT: Must include /api suffix (e.g., https://your-backend.onrender.com/api)
# The code appends specific paths like /campaigns, /users, etc. to this base URL
VITE_API_GATEWAY_URL=http://localhost:5000/api

# Privy Authentication
VITE_PRIVY_APP_ID=your_privy_app_id_here

# Guardian/Relayer Wallet Address (for admin panel)
VITE_GUARDIAN_ADDRESS=0x_your_guardian_wallet_address_here
