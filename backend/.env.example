# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# MongoDB connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourCluster

# ===========================================
# SERVER CONFIGURATION
# ===========================================
# The port your backend server will run on
PORT=5000

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173

# ===========================================
# AUTHENTICATION - PRIVY
# ===========================================
PRIVY_APP_ID=your_privy_app_id_here
PRIVY_APP_SECRET=your_privy_app_secret_here

# ===========================================
# BLOCKCHAIN CONFIGURATION (Polygon Amoy Testnet)
# ===========================================
# Deployer/Admin wallet private key (include 0x prefix)
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# Relayer wallet for gasless transactions
RELAYER_PRIVATE_KEY=0x_your_relayer_private_key_here
RELAYER_ADDRESS=0x_your_relayer_wallet_address_here

# Polygon Amoy RPC URL
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your_alchemy_key
POLYGON_AMOY_RPC=https://polygon-amoy.g.alchemy.com/v2/your_alchemy_key

# USDC Token Address on Amoy Testnet
USDC_TOKEN_ADDRESS_AMOY=0x_your_usdc_token_address_here
USDC_TOKEN_ADDRESS=0x_your_usdc_token_address_here

# Token Configuration
TOKEN_DECIMALS=6
INR_TO_WEI_RATE=85

# Development Settings
DEV_FAUCET_AUTO_MINT=true

# ===========================================
# IPFS/PINATA CONFIGURATION
# ===========================================
# Option 1: JWT (Recommended)
PINATA_JWT=your_pinata_jwt_token_here

# Option 2: API Key + Secret (Legacy)
PINATA_API_KEY=your_pinata_api_key_here
PINATA_API_SECRET=your_pinata_api_secret_here

# ===========================================
# CLOUDINARY (Image Storage)
# ===========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here


# ===========================================
# EMAIL SERVICE (SMTP)
# ===========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password_here
